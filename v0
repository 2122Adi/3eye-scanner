def check_path(s, base, path):
    url = base.rstrip("/") + path
    try:
        r = s.get(url, timeout=TIMEOUT, verify=False,
                  allow_redirects=False, headers={"User-Agent": UA})
        return path, r.status_code, len(r.content), r.text[:200]
    except Exception:
        return path, 0, 0, ""

def recon_paths(s, base_url):
    section(f"8 · FILE & DIRECTORY ENUMERATION ({len(PATHS)} paths)")
    found = []

    with ThreadPoolExecutor(max_workers=MAX_WORKERS) as ex:
        futures = {ex.submit(check_path, s, base_url, p): p for p in PATHS}
        for f in as_completed(futures):
            path, status, size, preview = f.result()
            if status in (200, 206, 401, 403):
                note = {200:"ACCESSIBLE", 206:"PARTIAL", 401:"AUTH REQUIRED", 403:"FORBIDDEN"}[status]
                sev  = "CRITICAL" if status == 200 and any(x in path for x in [
                    ".env","wp-config",".git","credentials","backup","dump.sql",
                    "phpinfo","config.php","database.sql"]) \
                    else "HIGH" if status == 200 else \
                    "MEDIUM" if status == 401 else "LOW"
                find("Paths", sev, f"[{status} {note}] {path}",
                     preview[:100] if status == 200 else "",
                     "Remove or protect this resource." if sev in ("CRITICAL","HIGH") else "")
                found.append(path)

    if not found:
        print("  ✅ No sensitive paths exposed")



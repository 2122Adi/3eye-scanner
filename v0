def recon_technologies(s, url):
    section("6 · TECHNOLOGY FINGERPRINTING")
    r = get(s, url)
    if not r:
        print("  [!] Could not fetch"); return

    body    = r.text
    h_lower = {k.lower(): v.lower() for k, v in r.headers.items()}
    full    = body + " " + str(r.headers)
    detected = []

    for tech, patterns in TECH_SIGS.items():
        for pat in patterns:
            if re.search(pat, full, re.IGNORECASE):
                detected.append(tech)
                break

    # Header-based
    server = h_lower.get("server","")
    xpow   = h_lower.get("x-powered-by","")
    if server: find("Tech","INFO",f"Server header: {server}","")
    if xpow:   find("Tech","MEDIUM",f"X-Powered-By: {xpow}","",
                    "Remove X-Powered-By header.")

    for t in detected:
        find("Tech","INFO",f"Technology detected: {t}","")

    # Meta generator
    soup = BeautifulSoup(body, "html.parser")
    gen  = soup.find("meta", attrs={"name":"generator"})
    if gen:
        find("Tech","MEDIUM",f"Meta generator tag: {gen.get('content','')}","",
             "Remove meta generator tag — reveals CMS/version.")

    # JS library versions in scripts
    for script in soup.find_all("script", src=True):
        src = script["src"]
        ver = re.search(r"[\-/](\d+\.\d+[\.\d]*)", src)
        if ver and any(k.lower() in src.lower()
                       for k in ["jquery","react","vue","angular","lodash","moment"]):
            find("Tech","LOW",f"JS lib version in URL: {src[-80:]}",ver.group(0),
                 "Consider integrity checks (SRI) and keep libs updated.")

    # builtwith (local heuristic, no API key)
    if BW_AVAILABLE:
        try:
            bw = bw_lib.builtwith(url)
            for cat, techs in bw.items():
                find("Tech","INFO",f"BuiltWith [{cat}]", ", ".join(techs[:8]))
        except Exception:
            pass

    # robots.txt / sitemap
    for path in ["/robots.txt", "/sitemap.xml", "/sitemap_index.xml"]:
        rr = get(s, url.rstrip("/").rsplit("/",1)[0] + path)
        if rr and rr.status_code == 200:
            find("Tech","INFO",f"Found: {path}",
                 rr.text[:300])



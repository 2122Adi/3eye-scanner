def session():
    s = requests.Session()
    s.headers["User-Agent"] = UA
    return s

def get(s, url, **kw):
    try:
        return s.get(url, timeout=TIMEOUT, verify=False,
                     allow_redirects=True, **kw)
    except Exception:
        return None

def head(s, url, **kw):
    try:
        return s.head(url, timeout=TIMEOUT, verify=False,
                      allow_redirects=True, **kw)
    except Exception:
        return None


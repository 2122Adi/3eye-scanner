#  1. DNS — A, AAAA, MX, NS, TXT, CNAME, SOA, SPF, DMARC
# ══════════════════════════════════════════════════════
def recon_dns(host):
    section("1 · DNS ENUMERATION")
    record_types = ["A","AAAA","MX","NS","TXT","CNAME","SOA","SRV","CAA"]

    for rtype in record_types:
        try:
            answers = dns.resolver.resolve(host, rtype, lifetime=6)
            vals = [str(r) for r in answers]
            find("DNS", "INFO", f"DNS {rtype} records", "\n".join(vals))
        except dns.resolver.NXDOMAIN:
            find("DNS","INFO","Domain does not exist (NXDOMAIN)","")
            break
        except Exception:
            pass

    # SPF check
    try:
        spf_found = False
        for r in dns.resolver.resolve(host, "TXT", lifetime=6):
            val = str(r)
            if "v=spf1" in val:
                spf_found = True
                find("DNS","GOOD","SPF record found", val)
                if "+all" in val:
                    find("DNS","CRITICAL","SPF uses +all (allows anyone to send)",val,
                         "Change +all to ~all or -all immediately.")
        if not spf_found:
            find("DNS","MEDIUM","No SPF record — email spoofing possible","",
                 "Add a TXT SPF record: v=spf1 include:... -all")
    except Exception:
        pass

    # DMARC
    try:
        for r in dns.resolver.resolve(f"_dmarc.{host}", "TXT", lifetime=6):
            val = str(r)
            if "v=DMARC1" in val:
                find("DNS","GOOD","DMARC record found", val)
                if "p=none" in val:
                    find("DNS","MEDIUM","DMARC policy is 'none' (no enforcement)",val,
                         "Change DMARC policy to p=quarantine or p=reject.")
    except Exception:
        find("DNS","MEDIUM","No DMARC record found","",
             "Add _dmarc TXT record: v=DMARC1; p=reject; rua=mailto:...")

    # DNSSEC
    try:
        dns.resolver.resolve(host, "DNSKEY", lifetime=6)
        find("DNS","GOOD","DNSSEC enabled","")
    except Exception:
        find("DNS","LOW","DNSSEC not detected","",
             "Consider enabling DNSSEC for DNS integrity.")

    # Zone transfer attempt (harmless probe)
    try:
        ns_records = dns.resolver.resolve(host, "NS", lifetime=6)
        for ns in ns_records:
            ns_host = str(ns).rstrip(".")
            try:
                z = dns.zone.from_xfr(dns.query.xfr(ns_host, host, timeout=4))
                names = [str(n) for n in z.nodes.keys()]
                find("DNS","CRITICAL",
                     f"Zone transfer ALLOWED on {ns_host}",
                     "\n".join(names[:20]),
                     "Disable AXFR on all nameservers immediately.")
            except Exception:
                find("DNS","GOOD",f"Zone transfer denied by {ns_host}","")
    except Exception:
        pass

    # Subdomains via DNS brute (small list, passive)
    sub_wordlist = [
        "www","mail","ftp","admin","api","dev","staging","test","beta","app",
        "portal","vpn","remote","cdn","static","media","blog","shop","store",
        "dashboard","login","secure","mx","smtp","pop","imap","webmail",
        "support","help","docs","status","monitor","jenkins","gitlab","jira",
    ]
    section("1b · SUBDOMAIN BRUTEFORCE (DNS)")
    found_subs = []
    def check_sub(sub):
        fqdn = f"{sub}.{host}"
        try:
            dns.resolver.resolve(fqdn, "A", lifetime=4)
            return fqdn
        except Exception:
            return None

    with ThreadPoolExecutor(max_workers=20) as ex:
        for result in ex.map(check_sub, sub_wordlist):
            if result:
                found_subs.append(result)
                find("DNS","HIGH",f"Subdomain found: {result}","",
                     "Ensure this subdomain is intentional and secured.")

    if not found_subs:
        print("  ✅ No common subdomains found via DNS brute")

    return found_subs



all_findings = []

def find(category, severity, title, detail="", rec=""):
    all_findings.append(dict(category=category, severity=severity,
                             title=title, detail=detail, rec=rec))
    icon  = SEV_ICON.get(severity, "⚪")
    color = SEV_COL.get(severity, C.RESET)
    print(f"  {icon} {color}{C.BOLD}[{severity}]{C.RESET} {title}")
    if detail:
        for line in str(detail).splitlines()[:4]:
            print(f"      {C.DIM}{line}{C.RESET}")
    if rec:
        print(f"      {C.GREEN}→ {rec}{C.RESET}")

def section(title):
    print(f"\n{C.CYAN}{C.BOLD}{'─'*55}")
    print(f"  {title}")
    print(f"{'─'*55}{C.RESET}")


    "X-XSS-Protection":          ("LOW",   "Add X-XSS-Protection: 1; mode=block"),
    "Cross-Origin-Opener-Policy":("LOW",   "Add COOP: same-origin"),
    "Cross-Origin-Resource-Policy":("LOW", "Add CORP: same-origin"),
}
INFO_HEADERS = ["Server","X-Powered-By","X-AspNet-Version","X-AspNetMvc-Version",
                "X-Generator","X-Runtime","X-Version","Via","X-Drupal-Cache",
                "X-Pingback","X-CF-Powered-By","X-Litespeed-Cache"]

def recon_headers(s, url):
    section("5 · HTTP HEADERS & SERVER FINGERPRINT")
    r = get(s, url)
    if not r:
        print("  [!] Could not fetch page"); return

    headers = {k.lower(): v for k, v in r.headers.items()}

    find("Headers","INFO",f"HTTP Status: {r.status_code} | Final URL: {r.url}","")
    find("Headers","INFO",f"Response size: {len(r.content)} bytes","")

    for h, (sev, rec) in SECURITY_HEADERS.items():
        if h.lower() not in headers:
            find("Headers", sev, f"Missing: {h}", "", rec)
        else:
            val = headers[h.lower()]
            # Extra checks
            if h == "Content-Security-Policy":
                issues = []
                if "unsafe-inline" in val: issues.append("unsafe-inline")
                if "unsafe-eval"   in val: issues.append("unsafe-eval")
                if "*"             in val: issues.append("wildcard *")
                if issues:
                    find("Headers","MEDIUM",f"CSP has weak directives: {', '.join(issues)}",
                         val, "Remove unsafe directives from CSP.")
            if h == "Strict-Transport-Security":
                if "max-age" not in val.lower():
                    find("Headers","MEDIUM","HSTS missing max-age",val)
                else:
                    age = re.search(r"max-age=(\d+)", val)
                    if age and int(age.group(1)) < 15552000:
                        find("Headers","LOW","HSTS max-age too short (<180 days)",val,
                             "Use max-age=31536000 minimum.")

    for h in INFO_HEADERS:
        if h.lower() in headers:
            find("Headers","MEDIUM",f"Server fingerprint leaked — {h}: {headers[h.lower()]}",
                 "", f"Remove/obscure '{h}' header.")

    # Cookie flags
    for sc in r.headers.get("Set-Cookie","").split(","):
        if not sc.strip(): continue
        issues = []
        if "secure"   not in sc.lower(): issues.append("missing Secure")
        if "httponly" not in sc.lower(): issues.append("missing HttpOnly")
        if "samesite" not in sc.lower(): issues.append("missing SameSite")
        if issues:
            name = sc.strip().split("=")[0]
            find("Headers","HIGH",f"Cookie '{name}' insecure flags",
                 ", ".join(issues),"Set Secure; HttpOnly; SameSite=Strict")

    # CORS probe
    r2 = get(s, url, headers={"Origin":"https://evil.example.com"})
    if r2:
        acao = r2.headers.get("Access-Control-Allow-Origin","")
        acac = r2.headers.get("Access-Control-Allow-Credentials","")
        if acao == "*":
            find("Headers","MEDIUM","CORS: wildcard origin (*)",acao,
                 "Restrict CORS to trusted origins.")
        elif acao == "https://evil.example.com":
            find("Headers","HIGH","CORS: reflects arbitrary origin",acao,
                 "Validate Origin against allowlist.")
        if acac.lower() == "true" and acao in ("*","https://evil.example.com"):
            find("Headers","CRITICAL","CORS: credentials + permissive origin",
                 f"{acao} / {acac}","Never combine credentials:true with wildcard.")

    return r



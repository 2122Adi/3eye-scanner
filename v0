#  4. SSL / TLS DEEP ANALYSIS
# ══════════════════════════════════════════════════════
def recon_ssl(host, port=443):
    section("4 · SSL / TLS DEEP ANALYSIS")
    try:
        # Basic cert via ssl module
        ctx = ssl.create_default_context()
        with ctx.wrap_socket(socket.create_connection((host, port), timeout=TIMEOUT),
                             server_hostname=host) as sock:
            cert   = sock.getpeercert()
            cipher = sock.cipher()
            proto  = sock.version()

            find("SSL","INFO",f"Protocol: {proto} | Cipher: {cipher[0]} | Bits: {cipher[2]}","")

            if proto in ("SSLv2","SSLv3","TLSv1","TLSv1.1"):
                find("SSL","CRITICAL",f"Outdated protocol: {proto}","",
                     "Disable TLS 1.0/1.1, enforce TLS 1.2+")

            if cipher[2] and cipher[2] < 128:
                find("SSL","HIGH",f"Weak cipher key size: {cipher[2]} bits","",
                     "Use 256-bit ciphers.")

            # Cert expiry
            exp_str = cert.get("notAfter","")
            if exp_str:
                exp  = datetime.datetime.strptime(exp_str, "%b %d %H:%M:%S %Y %Z")
                days = (exp - datetime.datetime.utcnow()).days
                sev  = "CRITICAL" if days < 0 else ("HIGH" if days < 14 else
                        "MEDIUM" if days < 30 else "GOOD")
                msg  = "EXPIRED" if days < 0 else f"Expires in {days} days"
                find("SSL", sev, f"Certificate: {msg}", exp_str)

            # Subject / issuer
            subj   = dict(x[0] for x in cert.get("subject",[]))
            issuer = dict(x[0] for x in cert.get("issuer",[]))
            find("SSL","INFO",f"Subject CN: {subj.get('commonName','')}","")
            find("SSL","INFO",f"Issuer: {issuer.get('organizationName','')}","")

            if subj == issuer:
                find("SSL","HIGH","Self-signed certificate","",
                     "Use cert from trusted CA.")

            # SAN
            sans = cert.get("subjectAltName",[])
            if sans:
                san_vals = [v for t,v in sans]
                find("SSL","INFO","Subject Alt Names (SANs)",
                     ", ".join(san_vals[:15]))
                # Wildcard
                for v in san_vals:
                    if v.startswith("*."):
                        find("SSL","LOW",f"Wildcard cert: {v}","",
                             "Wildcards increase blast radius if key is compromised.")

        # Test weak protocols (by attempting connection with older ctx)
        for proto_name, proto_const in [
            ("TLSv1",   ssl.TLSVersion.TLSv1  if hasattr(ssl,"TLSVersion") else None),
            ("TLSv1.1", ssl.TLSVersion.TLSv1_1 if hasattr(ssl,"TLSVersion") else None),
        ]:
            if proto_const is None:
                continue
            try:
                ctx2 = ssl.SSLContext(ssl.PROTOCOL_TLS_CLIENT)
                ctx2.check_hostname = False
                ctx2.verify_mode    = ssl.CERT_NONE
                ctx2.minimum_version = proto_const
                ctx2.maximum_version = proto_const
                with ctx2.wrap_socket(
                    socket.create_connection((host, port), timeout=5),
                    server_hostname=host):
                    find("SSL","HIGH",f"Server accepts {proto_name}","",
                         f"Disable {proto_name} in server config.")
            except Exception:
                find("SSL","GOOD",f"Server rejects {proto_name}","")

        # Check via crt.sh (certificate transparency)
        s_tmp = session()
        r = get(s_tmp, f"https://crt.sh/?q={host}&output=json")
        if r and r.status_code == 200:
            try:
                certs = r.json()
                unique = {c["name_value"] for c in certs}
                find("SSL","INFO",
                     f"Certificate Transparency: {len(certs)} cert records, "
                     f"{len(unique)} unique names",
                     "\n".join(list(unique)[:15]))
                # Extra subdomains from CT
                subs = [n for n in unique if host in n and n != host and "*" not in n]
                if subs:
                    find("SSL","HIGH",
                         f"CT logs reveal {len(subs)} subdomains",
                         "\n".join(sorted(set(subs))[:20]),
                         "Ensure all subdomains are intentional and secured.")
            except Exception:
                pass

    except ConnectionRefusedError:
        find("SSL","INFO","Port 443 not open","")
    except Exception as e:
        find("SSL","INFO",f"SSL analysis error: {e}","")



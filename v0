def print_report(target, elapsed):
    counts = {}
    for f in all_findings:
        counts[f["severity"]] = counts.get(f["severity"], 0) + 1

    score = (counts.get("CRITICAL",0)*10 + counts.get("HIGH",0)*5 +
             counts.get("MEDIUM",0)*2 + counts.get("LOW",0)*1)

    risk = ("🔴 CRITICAL" if score >= 30 else
            "🟠 HIGH"     if score >= 15 else
            "🟡 MEDIUM"   if score >= 5  else
            "🟢 LOW")

    print(f"\n{C.BOLD}{C.CYAN}{'═'*60}")
    print(f"  VAPT RECON REPORT")
    print(f"{'═'*60}{C.RESET}")
    print(f"  Target    : {target}")
    print(f"  Scanned   : {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"  Duration  : {elapsed:.1f}s")
    print(f"  Risk Score: {score}  →  {risk}")
    print(f"{'─'*60}")
    print(f"  {C.RED}Critical: {counts.get('CRITICAL',0)}{C.RESET}  "
          f"{C.ORANGE}High: {counts.get('HIGH',0)}  "
          f"Medium: {counts.get('MEDIUM',0)}{C.RESET}  "
          f"{C.BLUE}Low: {counts.get('LOW',0)}{C.RESET}  "
          f"{C.DIM}Info: {counts.get('INFO',0)}{C.RESET}  "
          f"{C.GREEN}Good: {counts.get('GOOD',0)}{C.RESET}")
    print(f"{'═'*60}\n")

    for sev in ["CRITICAL","HIGH","MEDIUM","LOW","GOOD","INFO"]:
        group = [f for f in all_findings if f["severity"] == sev]
        if not group: continue
        icon  = SEV_ICON[sev]
        color = SEV_COL[sev]
        print(f"{color}{C.BOLD}{icon} {sev} ({len(group)}){C.RESET}")
        for f in group:
            print(f"  [{f['category']}] {f['title']}")
            if f["detail"] and sev in ("CRITICAL","HIGH"):
                print(f"    {C.DIM}{str(f['detail'])[:100]}{C.RESET}")
            if f["rec"]:
                print(f"    {C.GREEN}Fix: {f['rec']}{C.RESET}")
        print()


def save_report(target, path):
    report = {
        "target"    : target,
        "scanned_at": datetime.datetime.utcnow().isoformat()+"Z",
        "total"     : len(all_findings),
        "findings"  : all_findings,
    }
    with open(path,"w") as fh:
        json.dump(report, fh, indent=2, default=str)
    print(f"  💾 JSON report → {path}")



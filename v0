    "Strict-Transport-Security": ("HIGH",  "Add HSTS: max-age=31536000; includeSubDomains"),
    "Content-Security-Policy":   ("HIGH",  "Define CSP to prevent XSS."),
    "X-Frame-Options":           ("MEDIUM","Add X-Frame-Options: DENY"),

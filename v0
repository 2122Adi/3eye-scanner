#  11. WAYBACK MACHINE — HISTORICAL URLS
# ══════════════════════════════════════════════════════
def recon_wayback(s, host):
    section("11 · WAYBACK MACHINE (Historical URLs)")
    try:
        url = (f"https://web.archive.org/cdx/search/cdx"
               f"?url={host}/*&output=json&limit=200&fl=original,statuscode,timestamp"
               f"&collapse=urlkey&filter=statuscode:200")
        r = get(s, url)
        if not r or r.status_code != 200:
            print("  [!] Wayback unavailable"); return

        data = r.json()
        if len(data) <= 1:
            print("  ⚪ No archived URLs found"); return

        urls = [row[0] for row in data[1:]]
        find("Wayback","INFO",f"Wayback Machine: {len(urls)} archived URLs","")

        # Interesting paths in history
        interesting = []
        for u in urls:
            p = urllib.parse.urlparse(u).path
            if any(k in p.lower() for k in [
                "admin","login","config","backup","api","debug","test",
                "password","token","secret",".env","upload","shell",".php"
            ]):
                interesting.append(u)

        if interesting:
            find("Wayback","HIGH",
                 f"{len(interesting)} historically interesting URLs found",
                 "\n".join(interesting[:15]),
                 "Check if old sensitive endpoints are still accessible.")

        # Old file types
        ext_map = {}
        for u in urls:
            ext = os.path.splitext(urllib.parse.urlparse(u).path)[1].lower()
            if ext in (".php",".asp",".aspx",".jsp",".py",".rb",".sql",".zip",".bak",".log"):
                ext_map[ext] = ext_map.get(ext, 0) + 1

        if ext_map:
            find("Wayback","MEDIUM","Historical file types",
                 str(ext_map),
                 "Verify old files/endpoints are removed or secured.")

    except Exception as e:
        find("Wayback","INFO",f"Wayback check failed: {e}","")



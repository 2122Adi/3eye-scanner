def main():
    parser = argparse.ArgumentParser(
        description="VAPT Web Recon — 100% Free & Open Source",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="  Use ONLY on targets you own or have written permission to test.\n"
    )
    parser.add_argument("url", nargs="?", default=DEFAULT_TARGET,
                        help=f"Target URL (default: {DEFAULT_TARGET})")
    parser.add_argument("--output","-o", help="Save JSON report to file")
    parser.add_argument("--skip-ports",   action="store_true")
    parser.add_argument("--skip-paths",   action="store_true")
    parser.add_argument("--skip-wayback", action="store_true")
    args = parser.parse_args()

    target = args.url
    if not target.startswith(("http://","https://")):
        target = "https://" + target

    parsed = urllib.parse.urlparse(target)
    host   = parsed.hostname
    base   = f"{parsed.scheme}://{parsed.netloc}"

    print(__doc__)
    print(f"  Target : {C.BOLD}{target}{C.RESET}")
    print(f"  Base   : {base}")
    print(f"  Host   : {host}")
    print(f"  Time   : {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")

    s = session()
    t0 = time.time()

    recon_dns(host)
    recon_whois(host)
    recon_ip(host, s)
    recon_ssl(host)
    recon_headers(s, target)
    recon_technologies(s, target)

    if not args.skip_ports:
        recon_ports(host)

    if not args.skip_paths:
        recon_paths(s, base)

    recon_login(s, target)
    recon_emails(s, target)

    if not args.skip_wayback:
        recon_wayback(s, host)

    generate_dorks(host)
    print_report(target, time.time() - t0)

    if args.output:
        save_report(target, args.output)
    else:
        save_report(target, f"recon_{host}_{int(time.time())}.json")


if __name__ == "__main__":
    main()

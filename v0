#  9. LOGIN PAGE DEEP ANALYSIS
# ══════════════════════════════════════════════════════
def recon_login(s, url):
    section("9 · LOGIN PAGE DEEP ANALYSIS")
    r = get(s, url)
    if not r or r.status_code != 200:
        print("  [!] Could not access login page"); return

    soup = BeautifulSoup(r.text, "html.parser")
    body = r.text.lower()

    # Forms analysis
    forms = soup.find_all("form")
    if not forms:
        find("Login","INFO","No HTML forms found on page","")
        return

    find("Login","INFO",f"Found {len(forms)} form(s) on page","")

    for i, form in enumerate(forms):
        inputs = form.find_all("input")
        action = form.get("action","")
        method = form.get("method","get").lower()

        find("Login","INFO",f"Form {i+1}: method={method.upper()} action={action}","")

        if method == "get":
            find("Login","HIGH","Login form uses GET — credentials visible in URL","",
                 "Change form method to POST.")

        if action.startswith("http://"):
            find("Login","CRITICAL","Form submits credentials over HTTP","",
                 "Change form action to HTTPS endpoint.")

        # CSRF detection
        csrf_names = ["csrf","csrf_token","_token","csrfmiddlewaretoken",
                      "_csrf","authenticity_token","nonce","__requestverificationtoken"]
        has_csrf = any(
            inp.get("name","").lower() in csrf_names or
            inp.get("id","").lower() in csrf_names
            for inp in inputs
        )
        if has_csrf:
            find("Login","GOOD","CSRF token present in form","")
        else:
            find("Login","HIGH","No CSRF token detected in login form","",
                 "Implement CSRF protection on all state-changing forms.")

        # Hidden fields (might be interesting)
        for inp in inputs:
            if inp.get("type","").lower() == "hidden":
                name = inp.get("name","")
                val  = inp.get("value","")[:80]
                find("Login","INFO",f"Hidden field: {name}={val}","")

        # Password field checks
        for inp in inputs:
            if inp.get("type","").lower() == "password":
                if inp.get("autocomplete","").lower() not in ("off","new-password"):
                    find("Login","LOW","Password field: autocomplete not disabled","",
                         "Add autocomplete='off' to password inputs.")
                if inp.get("minlength"):
                    find("Login","INFO",f"Password minlength: {inp.get('minlength')}","")

    # CAPTCHA
    captcha_sigs = ["captcha","recaptcha","hcaptcha","turnstile","g-recaptcha","cf-turnstile"]
    has_captcha  = any(sig in body for sig in captcha_sigs)
    if has_captcha:
        find("Login","GOOD","CAPTCHA detected — brute-force harder","")
    else:
        find("Login","MEDIUM","No CAPTCHA on login page","",
             "Add CAPTCHA to prevent automated brute-force attacks.")

    # Rate limiting headers
    r2 = get(s, url)
    if r2:
        rl_headers = ["x-ratelimit-limit","retry-after","x-rate-limit",
                      "ratelimit-limit","x-ratelimit-remaining"]
        found_rl = [h for h in rl_headers if h in {k.lower() for k in r2.headers}]
        if found_rl:
            find("Login","GOOD",f"Rate-limit headers detected: {found_rl}","")
        else:
            find("Login","MEDIUM","No rate-limit headers visible","",
                 "Implement server-side rate limiting and lockout.")

    # Password reset link
    if "forgot" in body or "reset" in body or "password" in body:
        links = soup.find_all("a", href=True)
        for a in links:
            if any(k in a["href"].lower() for k in ["forgot","reset","recover"]):
                find("Login","INFO",f"Password reset link: {a['href']}","",
                     "Ensure reset tokens expire and are single-use.")

    # Enumerate response differences (manual note)
    find("Login","INFO",
         "Manually test: submit invalid username vs valid username",
         "Check if error messages differ — account enumeration risk.",
         "Always return generic: 'Invalid username or password'.")



# ══════════════════════════════════════════════════════
def recon_whois(host):
    section("2 · WHOIS INFORMATION")
    try:
        w = whois_lib.whois(host)
        fields = {
            "Registrar"        : w.registrar,
            "Creation Date"    : w.creation_date,
            "Expiration Date"  : w.expiration_date,
            "Updated Date"     : w.updated_date,
            "Name Servers"     : w.name_servers,
            "Status"           : w.status,
            "Emails"           : w.emails,
            "Org"              : w.org,
            "Country"          : w.country,
            "DNSSEC"           : w.dnssec,
        }
        for k, v in fields.items():
            if v:
                val = v if isinstance(v, str) else (
                    ", ".join(str(x) for x in v) if isinstance(v, list) else str(v))
                find("WHOIS","INFO", f"{k}: {val[:120]}","")

        # Expiry warning
        exp = w.expiration_date
        if exp:
            if isinstance(exp, list): exp = exp[0]
            days = (exp - datetime.datetime.now()).days
            if days < 0:
                find("WHOIS","CRITICAL","Domain has EXPIRED","",
                     "Renew domain immediately.")
            elif days < 30:
                find("WHOIS","HIGH",f"Domain expires in {days} days","",
                     "Renew domain before expiry.")
            elif days < 90:
                find("WHOIS","MEDIUM",f"Domain expires in {days} days","")

        # Privacy / registrant exposure
        if w.emails:
            emails = w.emails if isinstance(w.emails, list) else [w.emails]
            for email in emails:
                if email and "@" in email and "privacy" not in email.lower():
                    find("WHOIS","LOW",f"Registrant email exposed: {email}","",
                         "Enable WHOIS privacy protection.")
    except Exception as e:
        find("WHOIS","INFO",f"WHOIS lookup failed: {e}","")



#  MODULE 12 — WAYBACK MACHINE
# ══════════════════════════════════════════════════════════════════════════════
def recon_wayback(s, host):
    section("WAYBACK MACHINE — HISTORICAL URLS", "12")
    try:
        url = (f"https://web.archive.org/cdx/search/cdx?url={host}/*"
               f"&output=json&limit=500&fl=original,statuscode,timestamp"
               f"&collapse=urlkey&filter=statuscode:200")
        r = get(s, url)
        if not r or r.status_code != 200:
            print("  [!] Wayback unavailable"); return

        data = r.json()
        if len(data) <= 1:
            print("  ⚪ No archived URLs"); return

        all_urls = [row[0] for row in data[1:]]
        find("Wayback","INFO",f"{len(all_urls)} archived URLs","")

        # Interesting paths
        interesting = [u for u in all_urls
                       if any(k in urllib.parse.urlparse(u).path.lower() for k in
                              ["admin","login","config","backup","api","debug","test",
                               "password","token","secret",".env","upload","shell",
                               ".php","db","dump","export","import"])]
        if interesting:
            find("Wayback","HIGH",
                 f"{len(interesting)} sensitive historical URLs",
                 "\n".join(interesting[:20]),
                 "Check if old endpoints still exist.")

        # Old file extensions
        ext_count = {}
        for u in all_urls:
            ext = os.path.splitext(urllib.parse.urlparse(u).path)[1].lower()
            if ext in (".php",".asp",".aspx",".jsp",".py",".rb",
                       ".sql",".zip",".bak",".log",".xml",".json",".txt"):
                ext_count[ext] = ext_count.get(ext, 0) + 1
        if ext_count:
            find("Wayback","MEDIUM","Historical file types",str(ext_count),
                 "Verify old files are removed or secured.")

        # Unique subdomains from history
        subs = set()
        for u in all_urls:
            h = urllib.parse.urlparse(u).hostname or ""
            if h and h != host and h.endswith(host):
                subs.add(h)
        if subs:
            find("Wayback","MEDIUM",f"Subdomains in Wayback history",
                 "\n".join(sorted(subs)[:20]))

    except Exception as e:
        find("Wayback","INFO",f"Wayback error: {e}","")



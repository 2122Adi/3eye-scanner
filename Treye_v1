#  MODULE 1 — DNS FULL ENUMERATION
# ══════════════════════════════════════════════════════════════════════════════
def recon_dns(host):
    section("DNS FULL ENUMERATION", "01")

    for rtype in ["A","AAAA","MX","NS","TXT","CNAME","SOA","SRV","CAA","PTR","NAPTR"]:
        try:
            answers = dns.resolver.resolve(host, rtype, lifetime=7)
            vals    = [str(r) for r in answers]
            find("DNS","INFO",f"DNS {rtype}", "\n".join(vals))
        except dns.resolver.NXDOMAIN:
            find("DNS","INFO","NXDOMAIN — domain does not exist",""); break
        except Exception:
            pass

    # SPF
    try:
        spf = False
        for r in dns.resolver.resolve(host, "TXT", lifetime=7):
            v = str(r)
            if "v=spf1" in v:
                spf = True
                find("DNS","GOOD","SPF record present", v)
                if "+all" in v:
                    find("DNS","CRITICAL","SPF +all — anyone can spoof this domain",v,
                         "Replace +all with -all.")
                if "~all" in v:
                    find("DNS","MEDIUM","SPF ~all (soft fail) — consider -all",v)
        if not spf:
            find("DNS","MEDIUM","No SPF record","",
                 "Add: v=spf1 include:... -all")
    except Exception:
        pass

    # DMARC
    try:
        found_dmarc = False
        for r in dns.resolver.resolve(f"_dmarc.{host}", "TXT", lifetime=7):
            v = str(r)
            if "v=DMARC1" in v:
                found_dmarc = True
                find("DNS","GOOD","DMARC record present", v)
                if "p=none" in v:
                    find("DNS","MEDIUM","DMARC p=none (monitoring only)",v,
                         "Set p=quarantine or p=reject.")
        if not found_dmarc:
            find("DNS","MEDIUM","No DMARC record","",
                 "Add: v=DMARC1; p=reject; rua=mailto:dmarc@yourdomain.com")
    except Exception:
        find("DNS","MEDIUM","No DMARC record","",
             "Add _dmarc TXT: v=DMARC1; p=reject;")

    # DKIM (common selectors)
    dkim_selectors = ["default","google","mail","key1","k1","dkim","selector1","selector2","zoho","sendgrid","mailchimp"]
    for sel in dkim_selectors:
        try:
            dns.resolver.resolve(f"{sel}._domainkey.{host}", "TXT", lifetime=4)
            find("DNS","GOOD",f"DKIM selector found: {sel}","")
        except Exception:
            pass

    # DNSSEC
    try:
        dns.resolver.resolve(host, "DNSKEY", lifetime=6)
        find("DNS","GOOD","DNSSEC enabled","")
    except Exception:
        find("DNS","LOW","DNSSEC not detected","",
             "Enable DNSSEC for DNS integrity.")

    # Zone transfer
    try:
        ns_records = dns.resolver.resolve(host, "NS", lifetime=7)
        for ns in ns_records:
            ns_h = str(ns).rstrip(".")
            try:
                z = dns.zone.from_xfr(dns.query.xfr(ns_h, host, timeout=5))
                names = [str(n) for n in z.nodes.keys()]
                find("DNS","CRITICAL",f"Zone Transfer ALLOWED on {ns_h}",
                     "\n".join(names[:25]),
                     "Disable AXFR on ALL nameservers immediately.")
            except Exception:
                find("DNS","GOOD",f"Zone transfer blocked by {ns_h}","")
    except Exception:
        pass

    # Subdomain brute (expanded wordlist)
    sub_list = [
        "www","mail","ftp","admin","api","dev","staging","test","beta","app",
        "portal","vpn","remote","cdn","static","media","blog","shop","store",
        "dashboard","login","secure","mx","smtp","pop","imap","webmail",
        "support","help","docs","status","monitor","jenkins","gitlab","jira",
        "git","svn","ci","build","deploy","prod","production","demo","sandbox",
        "internal","intranet","extranet","legacy","old","new","v1","v2","v3",
        "auth","sso","identity","oauth","api2","backend","frontend","assets",
        "upload","download","files","images","video","stream","live","mail2",
        "ns1","ns2","ns3","mx1","mx2","smtp2","relay","bounce","list",
        "newsletter","crm","erp","hr","finance","office","connect","cloud",
        "backup","db","database","sql","redis","elastic","kibana","grafana",
        "prometheus","vault","consul","k8s","kubernetes","docker","registry",
    ]
    section("01b · SUBDOMAIN BRUTEFORCE (DNS)", "")
    found_subs = []

    def check_sub(sub):
        fqdn = f"{sub}.{host}"
        try:
            ans = dns.resolver.resolve(fqdn, "A", lifetime=4)
            ips = [str(r) for r in ans]
            return fqdn, ips
        except Exception:
            return None, None

    with ThreadPoolExecutor(max_workers=30) as ex:
        for fqdn, ips in ex.map(check_sub, sub_list):
            if fqdn:
                found_subs.append(fqdn)
                find("DNS","HIGH",f"Subdomain: {fqdn}",
                     "IPs: " + ", ".join(ips),
                     "Ensure subdomain is intentional and secured.")

    # Wildcard DNS detection
    rand_sub = "".join(random.choices(string.ascii_lowercase, k=12))
    try:
        dns.resolver.resolve(f"{rand_sub}.{host}", "A", lifetime=4)
        find("DNS","MEDIUM","Wildcard DNS detected","",
             "Wildcard DNS may make subdomain enumeration unreliable.")
    except Exception:
        find("DNS","GOOD","No wildcard DNS detected","")

    if not found_subs:
        print("  ✅ No common subdomains resolved")

    return found_subs



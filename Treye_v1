#  MODULE 2 — WHOIS + DOMAIN INTELLIGENCE
# ══════════════════════════════════════════════════════════════════════════════
def recon_whois(host):
    section("WHOIS + DOMAIN INTELLIGENCE", "02")
    try:
        w = whois_lib.whois(host)
        for label, attr in [
            ("Registrar",        "registrar"),
            ("Registrar URL",    "registrar_url"),
            ("Creation Date",    "creation_date"),
            ("Expiration Date",  "expiration_date"),
            ("Updated Date",     "updated_date"),
            ("Name Servers",     "name_servers"),
            ("Status",           "status"),
            ("Emails",           "emails"),
            ("Org",              "org"),
            ("Country",          "country"),
            ("State",            "state"),
            ("DNSSEC",           "dnssec"),
            ("WHOIS Server",     "whois_server"),
        ]:
            val = getattr(w, attr, None)
            if val:
                s = val if isinstance(val, str) else (
                    ", ".join(str(x) for x in (val if isinstance(val, list) else [val])))
                find("WHOIS","INFO",f"{label}: {s[:120]}","")

        # Domain age
        cd = w.creation_date
        if cd:
            if isinstance(cd, list): cd = cd[0]
            age = (datetime.datetime.now() - cd).days
            find("WHOIS","INFO",f"Domain age: {age} days (~{age//365} years)","")
            if age < 30:
                find("WHOIS","HIGH","Domain is very new (<30 days)","",
                     "New domains are higher risk — verify legitimacy.")

        # Expiry warning
        exp = w.expiration_date
        if exp:
            if isinstance(exp, list): exp = exp[0]
            days = (exp - datetime.datetime.now()).days
            sev  = "CRITICAL" if days < 0 else "HIGH" if days < 30 else "MEDIUM" if days < 90 else "GOOD"
            msg  = "EXPIRED" if days < 0 else f"Expires in {days} days"
            find("WHOIS", sev, f"Domain expiry: {msg}", str(exp))

        # Email exposure
        emails = w.emails
        if emails:
            for e in (emails if isinstance(emails, list) else [emails]):
                if e and "@" in e and "privacy" not in e.lower() and "protect" not in e.lower():
                    find("WHOIS","LOW",f"Registrant email exposed: {e}","",
                         "Enable WHOIS privacy / GDPR redaction.")
    except Exception as e:
        find("WHOIS","INFO",f"WHOIS lookup failed: {e}","")



                label = {200:"ACCESSIBLE",206:"PARTIAL",401:"AUTH REQUIRED",403:"FORBIDDEN"}[status]
                sev = ("CRITICAL" if status == 200 and any(k in path for k in [
                    ".env","wp-config",".git","credentials","backup","dump.sql",
                    "phpinfo","database.sql","shell","cmd","eval","actuator/env",
                    "swagger","openapi","/.aws"]) else
                    "HIGH" if status == 200 else
                    "HIGH" if status == 401 else "LOW")
                find("Paths", sev,
                     f"[HTTP {status} {label}] {path}",
                     preview[:120] if status == 200 else "",
                     "Remove or restrict access to this resource." if sev in ("CRITICAL","HIGH") else "")

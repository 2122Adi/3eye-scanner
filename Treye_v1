def recon_content(s, url):
    section("CONTENT ANALYSIS (Links, Forms, Params)", "14")
    r = get(s, url)
    if not r: return

    soup = BeautifulSoup(r.text, "html.parser")
    base = "/".join(url.split("/")[:3])

    # External links
    ext_links = []
    int_links = []
    for a in soup.find_all("a", href=True):
        href = a["href"]
        if href.startswith("http") and base not in href:
            ext_links.append(href)
        elif not href.startswith("#") and not href.startswith("mailto:"):
            int_links.append(href)

    find("Content","INFO",
         f"Links: {len(int_links)} internal, {len(ext_links)} external",
         "\n".join(ext_links[:10]))

    # Parameters on links (potential injection points)
    params = set()
    for a in soup.find_all("a", href=True):
        parsed = urllib.parse.urlparse(a["href"])
        qs = urllib.parse.parse_qs(parsed.query)
        params.update(qs.keys())
    if params:
        find("Content","INFO",
             f"URL parameter names found: {', '.join(sorted(params)[:20])}","",
             "Test each parameter for injection vulnerabilities.")

    # Forms and their inputs
    for form in soup.find_all("form"):
        inputs = [(i.get("name","?"), i.get("type","text"))
                  for i in form.find_all("input")]
        find("Content","INFO",
             f"Form: {form.get('method','GET').upper()} → {form.get('action','')}",
             "Inputs: " + ", ".join(f"{n}({t})" for n,t in inputs[:12]))

    # Interesting JS files
    for sc in soup.find_all("script", src=True):
        src = sc["src"]
        if any(k in src.lower() for k in ["api","config","auth","key","secret",
                                           "token","admin","private"]):
            find("Content","MEDIUM",f"Interesting JS file: {src}","",
                 "Review this file for exposed secrets or logic.")

    # iframes
    for iframe in soup.find_all("iframe"):
        src = iframe.get("src","")
        find("Content","LOW",f"iframe: {src[:80]}","",
             "Verify iframe source is trusted.")

    # Mixed content
    http_res = []
    for tag, attr in [("img","src"),("script","src"),("link","href"),("iframe","src")]:
        for el in soup.find_all(tag):
            val = el.get(attr,"")
            if val.startswith("http://"):
                http_res.append(f"<{tag}> {val[:80]}")
    if http_res:
        find("Content","HIGH",
             f"Mixed content: {len(http_res)} HTTP resources on HTTPS page",
             "\n".join(http_res[:8]),
             "Serve all assets over HTTPS.")
    else:
        find("Content","GOOD","No mixed content detected","")



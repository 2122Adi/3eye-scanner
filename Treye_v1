def recon_methods(s, url):
    section("HTTP METHOD TESTING", "11")
    dangerous = []
    for method in ["PUT","DELETE","TRACE","CONNECT","PATCH","OPTIONS","PROPFIND",
                   "PROPPATCH","MKCOL","COPY","MOVE","LOCK","UNLOCK","SEARCH"]:
        r = req(s, method, url)
        if r and r.status_code not in (405,501,400):
            sev = "HIGH" if method in ("PUT","DELETE","PROPFIND") else \
                  "MEDIUM" if method == "TRACE" else "INFO"
            find("Methods", sev, f"{method} allowed — HTTP {r.status_code}","",
                 f"Disable {method} unless required by your API.")
            dangerous.append(method)

    # OPTIONS — show allowed methods
    r_opt = req(s, "OPTIONS", url)
    if r_opt:
        allow = r_opt.headers.get("Allow","") or r_opt.headers.get("Access-Control-Allow-Methods","")
        if allow:
            find("Methods","INFO",f"OPTIONS Allow header: {allow}","")

    if not dangerous:
        print("  ✅ No dangerous HTTP methods detected")



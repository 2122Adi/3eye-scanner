def recon_login(s, url):
    section("LOGIN PAGE DEEP ANALYSIS", "09")
    r = get(s, url)
    if not r or r.status_code != 200:
        print("  [!] Could not access login page"); return

    soup = BeautifulSoup(r.text, "html.parser")
    body = r.text.lower()
    find("Login","INFO",f"Page title: {soup.title.string.strip() if soup.title else 'N/A'}","")

    forms = soup.find_all("form")
    if not forms:
        find("Login","INFO","No HTML forms found",""); return

    find("Login","INFO",f"{len(forms)} form(s) found","")

    for i, form in enumerate(forms):
        inputs = form.find_all("input")
        action = form.get("action","") or url
        method = form.get("method","get").lower()
        enctype = form.get("enctype","application/x-www-form-urlencoded")

        find("Login","INFO",
             f"Form {i+1}: method={method.upper()} | action={action[:80]} | enctype={enctype}","")

        if method == "get":
            find("Login","HIGH","Login form uses GET — credentials in URL","",
                 "Change method to POST.")
        if action.startswith("http://"):
            find("Login","CRITICAL","Form POSTs credentials to HTTP","",
                 "Change form action to HTTPS.")

        # CSRF
        csrf_names = {"csrf","csrf_token","_token","csrfmiddlewaretoken",
                      "_csrf","authenticity_token","nonce","__requestverificationtoken",
                      "verify_token","anticsrf"}
        has_csrf = any(
            inp.get("name","").lower() in csrf_names or
            inp.get("id","").lower() in csrf_names
            for inp in inputs
        )
        if has_csrf:

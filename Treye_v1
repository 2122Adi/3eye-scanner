def recon_headers(s, url):
    section("HTTP HEADERS + FINGERPRINT + CORS", "05")
    r = get(s, url)
    if not r:
        print("  [!] Could not fetch page"); return None

    hl = {k.lower(): v for k, v in r.headers.items()}
    find("Headers","INFO",
         f"Status: {r.status_code}  |  Size: {len(r.content)} bytes  |  Final: {r.url}","")

    # Redirect chain
    if r.history:
        chain = " → ".join(str(h.url) for h in r.history) + f" → {r.url}"
        find("Headers","INFO",f"Redirect chain ({len(r.history)} hops)", chain)

    for h, (sev, rec) in SEC_HEADERS.items():
        if h.lower() not in hl:
            find("Headers", sev, f"Missing: {h}", "", rec)
        else:
            val = hl[h.lower()]
            if h == "Content-Security-Policy":
                issues = []
                if "unsafe-inline" in val: issues.append("unsafe-inline")
                if "unsafe-eval"   in val: issues.append("unsafe-eval")
                if re.search(r"script-src[^;]*\*", val): issues.append("script-src wildcard")
                if issues:
                    find("Headers","MEDIUM",f"CSP weak: {', '.join(issues)}",val,
                         "Remove unsafe-inline, unsafe-eval, wildcards from CSP.")
            if h == "Strict-Transport-Security":
                m = re.search(r"max-age=(\d+)", val)
                if not m:
                    find("Headers","HIGH","HSTS missing max-age",val)
                elif int(m.group(1)) < 15552000:
                    find("Headers","LOW",f"HSTS max-age too short: {m.group(1)}s",val,
                         "Use max-age=31536000 minimum.")
                if "includesubdomains" not in val.lower():
                    find("Headers","LOW","HSTS missing includeSubDomains",val)
                if "preload" not in val.lower():
                    find("Headers","LOW","HSTS not preloaded",val,
                         "Add preload + submit to hstspreload.org")

    for h in LEAK_HEADERS:
        if h.lower() in hl:
            find("Headers","MEDIUM",
                 f"Tech fingerprint: {h}: {hl[h.lower()]}","",
                 f"Remove/obscure {h} header.")

    # Set-Cookie analysis
    all_sc = r.headers.get("Set-Cookie","")
    for sc in r.headers.getlist("Set-Cookie") if hasattr(r.headers, "getlist") else [all_sc]:
        if not sc: continue
        name   = sc.split("=")[0].strip()
        sl     = sc.lower()
        issues = []
        if "secure"   not in sl: issues.append("missing Secure")
        if "httponly" not in sl: issues.append("missing HttpOnly")
        if "samesite" not in sl: issues.append("missing SameSite")
        if "__session" in name.lower() or "auth" in name.lower():
            issues.append("looks like session/auth cookie")
        if issues:
            find("Headers","HIGH",f"Cookie '{name}': {', '.join(issues)}","",
                 "Set: Secure; HttpOnly; SameSite=Strict")

    # CORS
    for origin in ["https://evil.example.com","null","*"]:
        r2 = req(s, "GET", url, headers={"Origin": origin})
        if not r2: continue
        acao = r2.headers.get("Access-Control-Allow-Origin","")
        acac = r2.headers.get("Access-Control-Allow-Credentials","")
        acam = r2.headers.get("Access-Control-Allow-Methods","")
        if acao == "*":
            find("Headers","MEDIUM","CORS wildcard (*)",acao,
                 "Restrict CORS to specific trusted origins.")
        elif acao and acao not in ("","null") and origin not in ("*","null"):
            if acao == origin:
                find("Headers","HIGH","CORS reflects arbitrary Origin",
                     f"Sent: {origin}  Got: {acao}",
                     "Validate Origin against a server-side allowlist.")
        if acac.lower() == "true":
            if acao in ("*",origin):
                find("Headers","CRITICAL","CORS: Allow-Credentials + permissive origin",
                     f"Origin: {acao}  Credentials: {acac}",
                     "Never combine Allow-Credentials:true with wildcard/reflected origin.")
        if "DELETE" in acam or "PUT" in acam:
            find("Headers","MEDIUM",f"CORS allows dangerous methods: {acam}","")

    # Clickjacking
    if "x-frame-options" not in hl and "frame-ancestors" not in hl.get("content-security-policy",""):
        find("Headers","MEDIUM","Clickjacking possible — no frame protection","",
             "Add X-Frame-Options: DENY or CSP frame-ancestors 'none'")

    return r



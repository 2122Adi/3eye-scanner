#  MODULE 4 — SSL/TLS DEEP ANALYSIS + CT LOGS
# ══════════════════════════════════════════════════════════════════════════════
def recon_ssl(host, port=443):
    section("SSL / TLS DEEP ANALYSIS", "04")

    # Basic cert
    try:
        ctx = ssl.create_default_context()
        with ctx.wrap_socket(
            socket.create_connection((host, port), timeout=TIMEOUT),
            server_hostname=host) as sock:

            cert   = sock.getpeercert()
            cipher = sock.cipher()
            proto  = sock.version()

            find("SSL","INFO",f"Protocol: {proto}  |  Cipher: {cipher[0]}  |  Bits: {cipher[2]}","")

            if proto in ("SSLv2","SSLv3","TLSv1","TLSv1.1"):
                find("SSL","CRITICAL",f"Outdated protocol in use: {proto}","",
                     "Disable TLS 1.0/1.1 in server config; enforce TLS 1.2+")
            if cipher[2] and cipher[2] < 128:
                find("SSL","HIGH",f"Weak cipher key: {cipher[2]} bits","",
                     "Use AES-256-GCM ciphers.")
            if "RC4" in cipher[0] or "DES" in cipher[0] or "NULL" in cipher[0]:
                find("SSL","CRITICAL",f"Broken cipher in use: {cipher[0]}","",
                     "Disable RC4/DES/NULL ciphers immediately.")

            # Expiry
            exp_str = cert.get("notAfter","")
            if exp_str:
                exp  = datetime.datetime.strptime(exp_str, "%b %d %H:%M:%S %Y %Z")
                days = (exp - datetime.datetime.utcnow()).days
                sev  = ("CRITICAL" if days < 0 else "HIGH" if days < 14 else
                        "MEDIUM" if days < 30 else "LOW" if days < 60 else "GOOD")
                find("SSL", sev,
                     f"Certificate {'EXPIRED' if days < 0 else f'expires in {days} days'}",
                     exp_str)

            # Not-before
            nb_str = cert.get("notBefore","")
            if nb_str:
                nb = datetime.datetime.strptime(nb_str, "%b %d %H:%M:%S %Y %Z")
                find("SSL","INFO",f"Certificate valid from: {nb_str}","")

            subj   = dict(x[0] for x in cert.get("subject",[]))
            issuer = dict(x[0] for x in cert.get("issuer",[]))
            find("SSL","INFO",f"Subject CN : {subj.get('commonName','')}","")
            find("SSL","INFO",f"Issuer     : {issuer.get('organizationName','')} / {issuer.get('commonName','')}","")

            if subj == issuer:
                find("SSL","HIGH","Self-signed certificate","",
                     "Use cert from a trusted CA (Let's Encrypt is free).")

            # SANs
            sans = [v for t,v in cert.get("subjectAltName",[])]
            if sans:
                find("SSL","INFO",f"SANs ({len(sans)})", ", ".join(sans[:20]))
                for v in sans:
                    if v.startswith("*."):
                        find("SSL","LOW",f"Wildcard SAN: {v}","",
                             "Wildcards increase blast radius on key compromise.")

            # Serial
            serial = cert.get("serialNumber","")
            if serial:
                find("SSL","INFO",f"Certificate serial: {serial}","")

    except ConnectionRefusedError:
        find("SSL","INFO","Port 443 not open (no HTTPS)","")
    except ssl.SSLError as e:
        find("SSL","HIGH",f"SSL handshake error: {e}","")
    except Exception as e:
        find("SSL","INFO",f"SSL check error: {e}","")

    # Test weak protocol versions
    for proto_name, const_name in [("TLSv1","TLSv1"),("TLSv1.1","TLSv1_1")]:
        try:
            ctx2 = ssl.SSLContext(ssl.PROTOCOL_TLS_CLIENT)
            ctx2.check_hostname = False
            ctx2.verify_mode    = ssl.CERT_NONE
            v = getattr(ssl.TLSVersion, const_name, None)
            if v:
                ctx2.minimum_version = v
                ctx2.maximum_version = v
                with ctx2.wrap_socket(
                    socket.create_connection((host, port), timeout=5),
                    server_hostname=host):
                    find("SSL","HIGH",f"Server accepts {proto_name}","",
                         f"Disable {proto_name} in web server config.")
        except Exception:
            find("SSL","GOOD",f"Server rejects {proto_name}","")

    # HTTP → HTTPS redirect
    try:
        r = requests.get(f"http://{host}", timeout=TIMEOUT,
                         allow_redirects=False, verify=False,
                         headers={"User-Agent": UA})
        if r.status_code in (301,302,307,308):
            loc = r.headers.get("Location","")
            if loc.startswith("https://"):
                find("SSL","GOOD","HTTP correctly redirects to HTTPS","")
            else:
                find("SSL","MEDIUM","HTTP redirect does not point to HTTPS",loc)
        else:

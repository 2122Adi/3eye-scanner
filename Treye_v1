def print_report(target, elapsed):
    counts = {}
    for f in all_findings:
        counts[f["severity"]] = counts.get(f["severity"], 0) + 1

    risk_score = (counts.get("CRITICAL",0)*15 + counts.get("HIGH",0)*8 +
                  counts.get("MEDIUM",0)*3  + counts.get("LOW",0)*1)
    risk_label = ("🔴 CRITICAL RISK" if risk_score >= 50 else
                  "🟠 HIGH RISK"     if risk_score >= 25 else
                  "🟡 MEDIUM RISK"   if risk_score >= 10 else
                  "🟢 LOW RISK")

    print(f"\n{C.BOLD}{C.CYAN}{'═'*60}")
    print(f"  👁  3EYE RECON REPORT  —  by {AUTHOR}")
    print(f"{'═'*60}{C.RESET}")
    print(f"  Target     : {target}")
    print(f"  Scanned at : {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"  Duration   : {elapsed:.1f}s")
    print(f"  Risk Score : {risk_score}  →  {risk_label}")
    print(f"  {'─'*56}")
    print(f"  {C.RED}Critical:{counts.get('CRITICAL',0):3}{C.RESET}  "
          f"{C.ORANGE}High:{counts.get('HIGH',0):3}  Medium:{counts.get('MEDIUM',0):3}{C.RESET}  "
          f"{C.BLUE}Low:{counts.get('LOW',0):3}{C.RESET}  "
          f"{C.DIM}Info:{counts.get('INFO',0):3}{C.RESET}  "
          f"{C.GREEN}Good:{counts.get('GOOD',0):3}{C.RESET}")
    print(f"{C.CYAN}{C.BOLD}{'═'*60}{C.RESET}\n")

    for sev in ["CRITICAL","HIGH","MEDIUM","LOW","GOOD","INFO"]:
        group = [f for f in all_findings if f["severity"] == sev]
        if not group: continue
        print(f"{SEV_COL[sev]}{C.BOLD}{SEV_ICON[sev]} {sev} ({len(group)}){C.RESET}")
        for f in group:
            print(f"  [{f['category']}] {f['title']}")
            if f["detail"] and sev in ("CRITICAL","HIGH"):
                print(f"    {C.DIM}{f['detail'][:110]}{C.RESET}")
            if f["rec"]:
                print(f"    {C.GREEN}↳ {f['rec']}{C.RESET}")
        print()


def save_report(target, path):
    data = {
        "tool": "3eye",
        "version": VERSION,
        "author": AUTHOR,
        "target": target,
        "scanned_at": datetime.datetime.utcnow().isoformat()+"Z",
        "total": len(all_findings),
        "findings": all_findings,
    }
    with open(path, "w") as fh:
        json.dump(data, fh, indent=2, default=str)
    print(f"\n  💾 JSON report saved: {C.GREEN}{path}{C.RESET}")



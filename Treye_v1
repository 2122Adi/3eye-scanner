#  MAIN
# ══════════════════════════════════════════════════════════════════════════════
def main():
    parser = argparse.ArgumentParser(
        description=f"3eye v{VERSION} — Advanced VAPT Web Recon by {AUTHOR}",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"  Example: python 3eye.py https://example.com --output report.json\n"
               f"  ⚠  Authorized use only.\n"
    )
    parser.add_argument("url", nargs="?", default=DEFAULT_TARGET,
                        help=f"Target URL (default: {DEFAULT_TARGET})")
    parser.add_argument("--output", "-o", default=None,
                        help="JSON output file (auto-named if omitted)")
    parser.add_argument("--skip-ports",   action="store_true", help="Skip port scan")
    parser.add_argument("--skip-paths",   action="store_true", help="Skip path enum")
    parser.add_argument("--skip-wayback", action="store_true", help="Skip Wayback")
    parser.add_argument("--quick", "-q",  action="store_true",
                        help="Quick mode: skip ports + wayback")
    args = parser.parse_args()

    if args.quick:
        args.skip_ports   = True
        args.skip_wayback = True

    target = args.url
    if not target.startswith(("http://","https://")):
        target = "https://" + target

    parsed = urllib.parse.urlparse(target)
    host   = parsed.hostname
    base   = f"{parsed.scheme}://{parsed.netloc}"

    banner(target, host)

    s  = make_session()
    t0 = time.time()

    recon_dns(host)
    recon_whois(host)
    recon_ip(host, s)
    recon_ssl(host)
    recon_headers(s, target)
    recon_technologies(s, target)

    if not args.skip_ports:
        recon_ports(host)

    if not args.skip_paths:
        recon_paths(s, base)

    recon_login(s, target)
    recon_disclosure(s, target)
    recon_methods(s, target)
    recon_content(s, target)

    if not args.skip_wayback:
        recon_wayback(s, host)

    generate_dorks(host)
    print_report(target, time.time() - t0)

    out = args.output or f"3eye_{host}_{int(time.time())}.json"
    save_report(target, out)


if __name__ == "__main__":
    main()

# ── HTTP session ───────────────────────────────────────────────────────────────
def make_session():
    s = requests.Session()
    s.headers.update({"User-Agent": UA,
                       "Accept-Language": "en-US,en;q=0.9",
                       "Accept": "text/html,application/xhtml+xml,*/*;q=0.8"})
    return s

def get(s, url, **kw):
    try:
        return s.get(url, timeout=TIMEOUT, verify=False,
                     allow_redirects=True, **kw)
    except Exception:
        return None

def req(s, method, url, **kw):
    try:
        return s.request(method, url, timeout=TIMEOUT, verify=False, **kw)
    except Exception:
        return None



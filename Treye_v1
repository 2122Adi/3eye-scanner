def check_path_req(s, base, path):
    url = base.rstrip("/") + path
    try:
        r = s.get(url, timeout=TIMEOUT, verify=False,
                  allow_redirects=False, headers={"User-Agent": UA})
        return path, r.status_code, len(r.content), r.text[:300]
    except Exception:
        return path, 0, 0, ""


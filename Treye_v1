def recon_ip(host, s):
    section("IP / GEO / ASN / THREAT INTEL", "03")
    try:
        ip = socket.gethostbyname(host)
        find("IP","INFO",f"Resolved IP: {ip}","")

        # Check if CDN/proxy (multiple IPs)
        all_ips = list({str(r) for r in dns.resolver.resolve(host, "A", lifetime=6)})
        if len(all_ips) > 1:
            find("IP","INFO",f"Multiple A records (load balanced / CDN): {', '.join(all_ips)}","")

        # ip-api.com (free, 45 req/min)
        r = get(s, f"http://ip-api.com/json/{ip}?fields=status,country,countryCode,"
                   f"regionName,city,org,as,isp,proxy,hosting,reverse,mobile,timezone")
        if r and r.status_code == 200:
            d = r.json()
            find("IP","INFO","Geo",
                 f"{d.get('city')}, {d.get('regionName')}, {d.get('country')} [{d.get('countryCode')}] | TZ: {d.get('timezone')}")
            find("IP","INFO","Network",
                 f"ISP: {d.get('isp')} | Org: {d.get('org')} | ASN: {d.get('as')}")
            if d.get("proxy"):
                find("IP","MEDIUM","IP flagged as proxy/VPN/Tor by ip-api","",
                     "Investigate whether proxy usage is intentional.")
            if d.get("hosting"):
                find("IP","INFO","Hosted on datacenter / cloud infrastructure","")
            rev = d.get("reverse","")
            if rev and rev != ip:
                find("IP","INFO",f"Reverse DNS: {rev}","")

        # Shodan InternetDB (no key needed)
        r2 = get(s, f"https://internetdb.shodan.io/{ip}")
        if r2 and r2.status_code == 200:
            d2 = r2.json()
            ports  = d2.get("ports", [])
            vulns  = d2.get("vulns", [])
            tags   = d2.get("tags", [])
            cpes   = d2.get("cpes", [])
            hostnames = d2.get("hostnames", [])
            if hostnames:
                find("IP","INFO",f"Shodan hostnames: {', '.join(hostnames[:8])}","")
            if ports:
                find("IP","HIGH",f"Shodan open ports: {sorted(ports)}","",
                     "Close unused ports; firewall-restrict others.")
            if vulns:
                for v in vulns:
                    find("IP","CRITICAL",f"CVE on this IP: {v}","",
                         f"https://nvd.nist.gov/vuln/detail/{v}")
            if cpes:
                find("IP","MEDIUM","CPE fingerprints (Shodan)","\n".join(cpes[:10]))
            if tags:
                find("IP","INFO",f"Shodan tags: {', '.join(tags)}","")

        # IPinfo.io (free, 50k/month)
        r3 = get(s, f"https://ipinfo.io/{ip}/json")
        if r3 and r3.status_code == 200:
            d3 = r3.json()
            if d3.get("bogon"):
                find("IP","MEDIUM","IP is a bogon (private/reserved) address","")
            if d3.get("org"):
                find("IP","INFO",f"IPinfo org: {d3['org']}","")
            if d3.get("abuse"):
                find("IP","INFO",f"Abuse contact: {d3['abuse'].get('email','')}","")

        # AbuseIPDB check (free, no key needed for basic lookup via HTML)
        # BGPView ASN
        r4 = get(s, f"https://api.bgpview.io/ip/{ip}")
        if r4 and r4.status_code == 200:
            d4 = r4.json().get("data", {})
            for p in d4.get("prefixes", [])[:3]:
                asn  = p.get("asn", {})
                find("IP","INFO",
                     f"BGP: {p.get('prefix')} | ASN{asn.get('asn','')} {asn.get('name','')} [{asn.get('country_code','')}]","")

        # GreyNoise (free community API)
        r5 = get(s, f"https://api.greynoise.io/v3/community/{ip}")
        if r5 and r5.status_code == 200:
            d5 = r5.json()
            noise = d5.get("noise", False)
            riot  = d5.get("riot",  False)
            classification = d5.get("classification","")
            name  = d5.get("name","")
            if noise:
                sev = "HIGH" if classification == "malicious" else "MEDIUM"
                find("IP", sev, f"GreyNoise: IP is scanning the internet ({classification})",
                     name, "This IP is actively scanning — investigate.")
            elif riot:
                find("IP","GOOD",f"GreyNoise RIOT: known benign service ({name})","")
            else:
                find("IP","INFO","GreyNoise: IP not in mass-scan database","")

    except Exception as e:
        find("IP","INFO",f"IP recon error: {e}","")



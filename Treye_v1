def recon_technologies(s, url):
    section("TECHNOLOGY FINGERPRINTING", "06")
    r = get(s, url)
    if not r:
        print("  [!] Could not fetch"); return

    body    = r.text
    full    = body + " " + str(dict(r.headers))
    soup    = BeautifulSoup(body, "html.parser")
    hl      = {k.lower(): v for k, v in r.headers.items()}

    detected = set()
    for tech, patterns in TECH_SIGS.items():
        for pat in patterns:
            if re.search(pat, full, re.IGNORECASE):
                detected.add(tech)
                break

    for t in sorted(detected):
        find("Tech","INFO",f"Detected: {t}","")

    # Meta generator
    gen = soup.find("meta", attrs={"name": re.compile("generator", re.I)})
    if gen and gen.get("content"):
        find("Tech","MEDIUM",f"Meta generator: {gen['content']}","",
             "Remove meta generator — reveals CMS version.")

    # JS lib versions in script src
    for sc in soup.find_all("script", src=True):
        src = sc["src"]
        ver = re.search(r"[\-/v](\d+\.\d+[\.\d]*)", src)
        if ver and any(lib in src.lower() for lib in
                       ["jquery","react","vue","angular","lodash","moment","bootstrap"]):
            find("Tech","LOW",f"JS lib version in URL: ...{src[-70:]}",
                 f"Version: {ver.group(1)}",
                 "Use SRI hashes; keep libs updated.")

    # Inline JS secrets scan
    for sc in soup.find_all("script"):
        if not sc.get("src") and sc.string:
            text = sc.string
            for pat, label in [
                (r'(?:api[_-]?key|apikey)\s*[=:]\s*["\']([A-Za-z0-9\-_]{16,})["\']', "API Key"),
                (r'(?:secret|password|passwd)\s*[=:]\s*["\']([^"\']{6,})["\']', "Secret/Password"),
                (r'(?:token|auth_token|access_token)\s*[=:]\s*["\']([A-Za-z0-9\-_\.]{20,})["\']', "Token"),
                (r'(?:aws_access_key_id|AWS_ACCESS)\s*[=:]\s*["\']([A-Z0-9]{20})["\']', "AWS Key"),
                (r'(?:private_key|privateKey)\s*[=:]\s*["\']([^"\']{16,})["\']', "Private Key"),
                (r'https?://(?:localhost|127\.0\.0\.1|192\.168\.|10\.)\S+', "Internal URL"),
            ]:
                m = re.search(pat, text, re.IGNORECASE)
                if m:
